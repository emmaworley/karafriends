{
  "compilerOptions": {
    "target": "es6",
    "lib": ["es6", "dom"],
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true,
    "jsx": "react"
  },
  "include": ["src"],
  "exclude": ["**/*.test.ts"]
}
